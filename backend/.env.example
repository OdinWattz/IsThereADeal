# Backend Environment Variables
# Copy this to .env and fill in your values

# App
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
# SQLite (default for local dev)
DATABASE_URL=sqlite+aiosqlite:///./gamedeals.db
# PostgreSQL (for production, uncomment and fill in)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/gamedeals

# Steam API (get from https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=your_steam_api_key_here

# IsThereADeal API (get from https://isthereanydeal.com/dev/app/)
ITAD_API_KEY=your_itad_api_key_here

# Email alerts (optional, for price drop notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@gmail.com

# CORS origins (comma separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
