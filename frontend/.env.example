# Frontend Environment Variables
# Kopieer naar .env.local voor lokale ontwikkeling:
#   cp .env.example .env.local
#
# Voor productie: stel VITE_API_URL in als Vercel environment variable
# (zie Vercel dashboard → Settings → Environment Variables)

# URL van de backend (leeg laten voor lokale dev – dan gebruikt de Vite proxy)
VITE_API_URL=
# Voorbeeld productie:
# VITE_API_URL=https://jouw-backend.up.railway.app
